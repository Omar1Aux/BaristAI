import pandas as pd

df = pd.read_parquet("rancilio-portafilter-dataset.parquet")

p2 = df[df["process_id"] == 2]

print(p2[["temp", "pressure", "flowRate"]].describe())

print("Rows:", len(p2))
print("Invalid temp:", (~p2["temp"].between(0, 140)).sum())
print("Invalid pressure:", (~p2["pressure"].fillna(0).between(0, 15)).sum())
print("Invalid flowRate:", (p2["flowRate"].fillna(0) < 0).sum())